<script>
function updateClock() {
const now = new Date();
document.getElementById('clock').textContent = now.toLocaleTimeString('en-US', { hour12: false });
}
setInterval(updateClock, 1000);
updateClock();

function scrollToSection(id) {
document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
}

const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
const observer = new IntersectionObserver((entries) => {
entries.forEach(entry => {
if (entry.isIntersecting) {
entry.target.classList.add('visible');
}
});
}, observerOptions);
document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

const nodeData = {
artifact: {
title: 'Artifacts',
code: 'MEANS_01',
color: '#00d4ff',
desc: 'Physical objects designed to provide for human comfort, for the manipulation of things or materials, and for the manipulation of symbols. These are the tangible interfaces between human intent and environmental change.',
examples: 'Tools, Computers, Displays, Storage, Input Devices',
function: 'Motor Channel Extension',
metrics: { reach: 85, precision: 92, speed: 78 }
},
language: {
title: 'Language',
code: 'MEANS_02',
color: '#ff6b6b',
desc: 'The way in which the individual parcels out the picture of his world into the concepts that his mind uses to model that world, and the symbols that he attaches to those concepts and uses in consciously manipulating the concepts ("thinking").',
examples: 'Natural Language, Mathematics, Programming, Notation',
function: 'Conceptual Modeling System',
metrics: { reach: 95, precision: 88, speed: 82 }
},
methodology: {
title: 'Methodology',
code: 'MEANS_03',
color: '#ffd93d',
desc: 'The methods, procedures, strategies, etc., with which an individual organizes his goal-centered (problem-solving) activity. Methodology provides the structural framework for applying artifacts and language to complex problems.',
examples: 'Algorithms, Heuristics, Workflows, Design Patterns',
function: 'Activity Organization',
metrics: { reach: 70, precision: 90, speed: 85 }
},
training: {
title: 'Training',
code: 'MEANS_04',
color: '#6bcb77',
desc: 'The conditioning needed by the human being to bring his skills in using Means 1, 2, and 3 to the point where they are operationally effective. Training is the bridge between potential and actual capability.',
examples: 'Education, Practice, Muscle Memory, Cognitive Drills',
function: 'Skill Conditioning',
metrics: { reach: 60, precision: 95, speed: 90 }
}
};

let currentNode = 'artifact';

function selectNode(type) {
currentNode = type;
const data = nodeData[type];
const panel = document.getElementById('detail-panel');

document.getElementById('detail-indicator').style.background = data.color;
document.getElementById('detail-title').textContent = data.title;
document.getElementById('detail-title').style.color = data.color;
document.getElementById('detail-code').textContent = data.code;
document.getElementById('detail-desc').textContent = data.desc;
document.getElementById('detail-examples').textContent = data.examples;
document.getElementById('detail-function').textContent = data.function;

const bars = panel.querySelectorAll('.metric-bar');
bars[0].style.width = data.metrics.reach + '%';
bars[0].style.background = data.color;
bars[0].nextElementSibling.style.color = data.color;
bars[0].nextElementSibling.textContent = data.metrics.reach + '%';

bars[1].style.width = data.metrics.precision + '%';
bars[1].style.background = data.color;
bars[1].nextElementSibling.style.color = data.color;
bars[1].nextElementSibling.textContent = data.metrics.precision + '%';

bars[2].style.width = data.metrics.speed + '%';
bars[2].style.background = data.color;
bars[2].nextElementSibling.style.color = data.color;
bars[2].nextElementSibling.textContent = data.metrics.speed + '%';

panel.style.transform = 'scale(0.98)';
setTimeout(() => panel.style.transform = 'scale(1)', 150);
}

const bgCanvas = document.getElementById('bg-canvas');
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ canvas: bgCanvas, alpha: true, antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

const particlesGeometry = new THREE.BufferGeometry();
const particlesCount = 1500;
const posArray = new Float32Array(particlesCount * 3);
const colorArray = new Float32Array(particlesCount * 3);

for (let i = 0; i < particlesCount * 3; i += 3) {
posArray[i] = (Math.random() - 0.5) * 50;
posArray[i + 1] = (Math.random() - 0.5) * 50;
posArray[i + 2] = (Math.random() - 0.5) * 50;

const colorChoice = Math.random();
if (colorChoice < 0.25) {
colorArray[i] = 0; colorArray[i+1] = 0.83; colorArray[i+2] = 1;
} else if (colorChoice < 0.5) {
colorArray[i] = 1; colorArray[i+1] = 0.42; colorArray[i+2] = 0.42;
} else if (colorChoice < 0.75) {
colorArray[i] = 1; colorArray[i+1] = 0.85; colorArray[i+2] = 0.24;
} else {
colorArray[i] = 0.42; colorArray[i+1] = 0.8; colorArray[i+2] = 0.47;
}
}

particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
particlesGeometry.setAttribute('color', new THREE.BufferAttribute(colorArray, 3));

const particlesMaterial = new THREE.PointsMaterial({
size: 0.05,
vertexColors: true,
transparent: true,
opacity: 0.6,
blending: THREE.AdditiveBlending
});

const particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
scene.add(particlesMesh);

const lineGeometry = new THREE.BufferGeometry();
const linePositions = [];
for (let i = 0; i < 50; i++) {
const x1 = (Math.random() - 0.5) * 30;
const y1 = (Math.random() - 0.5) * 30;
const z1 = (Math.random() - 0.5) * 30;
const x2 = x1 + (Math.random() - 0.5) * 5;
const y2 = y1 + (Math.random() - 0.5) * 5;
const z2 = z1 + (Math.random() - 0.5) * 5;
linePositions.push(x1, y1, z1, x2, y2, z2);
}
lineGeometry.setAttribute('position', new THREE.Float32BufferAttribute(linePositions, 3));
const lineMaterial = new THREE.LineBasicMaterial({ color: 0x404060, transparent: true, opacity: 0.2 });
const lines = new THREE.LineSegments(lineGeometry, lineMaterial);
scene.add(lines);

camera.position.z = 15;

let mouseX = 0, mouseY = 0;
document.addEventListener('mousemove', (e) => {
mouseX = (e.clientX / window.innerWidth) * 2 - 1;
mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
});

function animateThree() {
requestAnimationFrame(animateThree);
particlesMesh.rotation.x += 0.0003;
particlesMesh.rotation.y += 0.0005;
particlesMesh.rotation.x += mouseY * 0.0005;
particlesMesh.rotation.y += mouseX * 0.0005;
lines.rotation.x += 0.0002;
lines.rotation.y += 0.0003;
renderer.render(scene, camera);
}
animateThree();

window.addEventListener('resize', () => {
camera.aspect = window.innerWidth / window.innerHeight;
camera.updateProjectionMatrix();
renderer.setSize(window.innerWidth, window.innerHeight);
});

const simCanvas = document.getElementById('simulation-canvas');
const simCtx = simCanvas.getContext('2d');
let simWidth, simHeight;

function resizeSim() {
const rect = simCanvas.parentElement.getBoundingClientRect();
simCanvas.width = rect.width;
simCanvas.height = rect.height;
simWidth = rect.width;
simHeight = rect.height;
}
resizeSim();
window.addEventListener('resize', resizeSim);

const simParticles = [];
const activeTypes = { artifact: true, language: true, methodology: true, training: true };

function createParticle() {
const types = ['artifact', 'language', 'methodology', 'training'];
const active = types.filter(t => activeTypes[t]);
if (active.length === 0) return null;

const type = active[Math.floor(Math.random() * active.length)];
const colors = {
artifact: '#00d4ff',
language: '#ff6b6b',
methodology: '#ffd93d',
training: '#6bcb77'
};

return {
x: Math.random() * simWidth,
y: Math.random() * simHeight,
vx: (Math.random() - 0.5) * 2,
vy: (Math.random() - 0.5) * 2,
size: Math.random() * 3 + 1,
color: colors[type],
type: type,
life: 1
};
}

for (let i = 0; i < 100; i++) {
const p = createParticle();
if (p) simParticles.push(p);
}

function updateSimulation() {
simCtx.fillStyle = 'rgba(0, 0, 0, 0.1)';
simCtx.fillRect(0, 0, simWidth, simHeight);

simParticles.forEach((p, i) => {
p.x += p.vx;
p.y += p.vy;

if (p.x < 0 || p.x > simWidth) p.vx *= -1;
if (p.y < 0 || p.y > simHeight) p.vy *= -1;

simCtx.beginPath();
simCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
simCtx.fillStyle = p.color;
simCtx.fill();

simParticles.forEach((p2, j) => {
if (i !== j) {
const dx = p.x - p2.x;
const dy = p.y - p2.y;
const dist = Math.sqrt(dx * dx + dy * dy);
if (dist < 100) {
simCtx.beginPath();
simCtx.moveTo(p.x, p.y);
simCtx.lineTo(p2.x, p2.y);
simCtx.strokeStyle = p.color;
simCtx.globalAlpha = 0.1 * (1 - dist / 100);
simCtx.stroke();
simCtx.globalAlpha = 1;
}
}
});
});

requestAnimationFrame(updateSimulation);
}
updateSimulation();

const toggles = document.querySelectorAll('.augment-toggle');
toggles.forEach(toggle => {
toggle.addEventListener('change', () => {
const type = toggle.dataset.type;
activeTypes[type] = toggle.checked;

const activeCount = Object.values(activeTypes).filter(v => v).length;
const statusEl = document.getElementById('system-status');
const statusSubEl = statusEl.nextElementSibling;

if (activeCount === 4) {
statusEl.textContent = 'FULLY AUGMENTED';
statusEl.style.color = 'white';
statusSubEl.textContent = 'All augmentation means active';
statusSubEl.style.color = '#6bcb77';
} else if (activeCount === 0) {
statusEl.textContent = 'BASELINE HUMAN';
statusEl.style.color = '#ff6b6b';
statusSubEl.textContent = 'No augmentation means active';
statusSubEl.style.color = '#ff6b6b';
} else {
statusEl.textContent = 'PARTIALLY AUGMENTED';
statusEl.style.color = '#ffd93d';
statusSubEl.textContent = activeCount + ' of 4 means active';
statusSubEl.style.color = '#ffd93d';
}

const complexity = 20 + (activeCount * 20) + Math.random() * 5;
const efficiency = 15 + (activeCount * 20) + Math.random() * 5;
const sensory = activeCount * 100 + Math.random() * 50;
const cognitive = activeCount * 150 + Math.random() * 50;
const motor = activeCount * 90 + Math.random() * 30;

document.getElementById('complexity-score').textContent = Math.round(complexity) + '%';
document.getElementById('efficiency-score').textContent = Math.round(efficiency) + '%';
document.getElementById('sensory-score').textContent = '+' + Math.round(sensory) + '%';
document.getElementById('cognitive-score').textContent = '+' + Math.round(cognitive) + '%';
document.getElementById('motor-score').textContent = '+' + Math.round(motor) + '%';

simParticles.length = 0;
const newCount = 20 + activeCount * 25;
for (let i = 0; i < newCount; i++) {
const p = createParticle();
if (p) simParticles.push(p);
}
});
});
</script>
</body>
</html>
